# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15&connection_limit=5"

# API
API_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@example.com
WEB_ORIGIN=http://localhost:3000

# Stock resolution (Finnhub free tier: https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Set to false for pure order-book (no instant mint fill)
MINT_UNFILLED_ORDERS=true
ENABLE_SCHEDULER=true

# Redis cache (leaderboard + portfolio)
# Upstash (recommended): REST works over HTTPS — copy from Connect tab
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
# Optional TCP fallback (if port 6379 is open):
# REDIS_URL=rediss://default:TOKEN@YOUR_DB.upstash.io:6379
CACHE_LEADERBOARD_TTL=60
CACHE_PORTFOLIO_TTL=30

# Kafka (optional — event-driven worker). Start: docker compose up -d
KAFKA_ENABLED=false
KAFKA_BROKERS=127.0.0.1:19092
KAFKA_CLIENT_ID=stockpredict-api
KAFKA_GROUP_ID=stockpredict-worker

# Email (Brevo) — https://www.brevo.com → API Keys + verify sender email
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=StockPredict
EMAIL_NOTIFICATIONS_ENABLED=true
APP_NAME=StockPredict

# Solana (devnet) — https://solana.com/docs/intro/quick-start
SOLANA_ENABLED=true
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_AUTO_ATTEST=false
SOLANA_AUTO_SETTLE=true
SOLANA_AUTO_INIT_MARKETS=false
# After: cd onchain && anchor deploy --provider.cluster devnet
# SOLANA_PROGRAM_ID=
# Base58 secret key (devnet only) — fund with: solana airdrop 2
# Get it from: node scripts/export-keypair.js <path-to-keypair.json>
# SOLANA_SETTLEMENT_SECRET=
# USDC vault (Phase 3) — your devnet SPL token mint. See docs/WEB3-SETUP-WINDOWS.md
# SOLANA_USDC_MINT=
SOLANA_USDC_DECIMALS=6
