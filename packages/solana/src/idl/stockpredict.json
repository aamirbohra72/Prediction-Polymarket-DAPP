        { "name": "authority", "signer": true },
        { "name": "market", "writable": true }
      ],
      "args": [{ "name": "winning_outcome", "type": "u8" }]
    }
  ],
  "accounts": [
    {
      "name": "Market",
      "discriminator": [219, 190, 213, 55, 0, 227, 198, 154],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "pubkey" },
          { "name": "market_key", "type": { "array": ["u8", 32] } },
          { "name": "strike_cents", "type": "u64" },
          { "name": "resolve_ts", "type": "i64" },
          { "name": "status", "type": "u8" },
          { "name": "winning_outcome", "type": "u8" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "errors": [
